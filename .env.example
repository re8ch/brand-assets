# Cloudflare R2
R2_BUCKET=brand-assets
R2_ACCOUNT_ID=6317b796fb47e67fadec3bc9a5ef0e8e
# Optional. When present, sync uses the S3-compatible R2 API and can delete stale remote objects.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional. Used by GitHub Actions/wrangler when S3 keys are not available. Upload-only, no stale deletion.
R2_CLOUDFLARE_API_TOKEN=

# Tencent COS
COS_BUCKET=brandassets-1301339749
COS_REGION=ap-guangzhou
COS_SECRET_ID=
COS_SECRET_KEY=

# Optional public base URLs written into manifest.json.
BRAND_ASSETS_GLOBAL_BASE_URL=https://brand-assets.re8ch.com
BRAND_ASSETS_CHINA_BASE_URL=https://zh-brand-assets.re8ch.com
